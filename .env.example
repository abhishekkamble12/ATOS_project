# .env.example
# Digital Twin of the Workforce Backend
# Built for National Hackathon Winning Entry
# Team Eklavya | Atos Srijan 2026
#
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="Digital Twin of the Workforce API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# ── Security ──────────────────────────────────────────────────────────────────
# CRITICAL: Change this to a strong random secret in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-minimum-32-chars-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Demo Credentials (remove in production) ────────────────────────────────────
DEMO_EMAIL=admin@atos.com
DEMO_PASSWORD=password123

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (hackathon / local dev):
DATABASE_URL=sqlite+aiosqlite:///./workforce_twin.db

# PostgreSQL (production) — uncomment and configure:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/workforce_twin

# ── Groq LLM ──────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=REPLACE_ME_WITH_YOUR_REAL_KEY
GROQ_MODEL=llama-3.1-70b-versatile
# Faster alternative: GROQ_MODEL=mixtral-8x7b-32768
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=512

# ── Redis (optional — gracefully degraded if not running) ─────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins for the Next.js frontend
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","https://your-app.vercel.app"]

# ── Sentence Transformer (RAG) ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
